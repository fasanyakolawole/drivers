<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".DriverApplication"
        android:allowBackup="true"
        android:icon="@drawable/main"
        android:label="@string/app_name"
        android:roundIcon="@drawable/main"
        android:supportsRtl="true"
        android:theme="@style/Theme.DriverApp"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Firebase default notification channel (shown when app is in background) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="driver_alerts" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_add_alert" />

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.DriverApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.DriverApp.NoActionBar" />

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.DriverApp.NoActionBar" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.DriverApp.NoActionBar" />

        <activity
            android:name=".PendingOrdersActivity"
            android:exported="false"
            android:label="@string/new_pending_order_title"
            android:theme="@style/Theme.DriverApp"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".OngoingOrdersActivity"
            android:exported="false"
            android:label="@string/ongoing_orders_title"
            android:theme="@style/Theme.DriverApp"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CompletedOrdersActivity"
            android:exported="false"
            android:label="@string/completed_orders_title"
            android:theme="@style/Theme.DriverApp"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".NewOrderActivity"
            android:exported="true"
            android:theme="@style/Theme.DriverApp.NoActionBar"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true">
            <!-- FCM notification tap opens this activity (set click_action in Firebase Console) -->
            <intent-filter>
                <action android:name="com.naijameals.driver.OPEN_NEW_ORDER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.DriverFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name=".service.LocationForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>
</manifest>
