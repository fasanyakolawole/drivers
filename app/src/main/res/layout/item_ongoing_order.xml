<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header: Order #, Status Badge, Earnings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="#F8FAF9"
            android:minHeight="72dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvOrderNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212529"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/statusBadgeContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_ongoing_badge_assigned"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:letterSpacing="0.5"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:background="@drawable/bg_earnings_box"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Earnings"
                    android:textSize="11sp"
                    android:textColor="#6c757d"
                    android:textAllCaps="true"
                    android:letterSpacing="0.5"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/success"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E9ECEF"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pickup Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_place"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6c757d"
                    android:textAllCaps="true"
                    android:letterSpacing="0.5"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvRestaurant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212529"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvRestaurantAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#6c757d"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/rowRestaurantPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#E8F5E9"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_phone_green"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvRestaurantPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Delivery Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6c757d"
                    android:textAllCaps="true"
                    android:letterSpacing="0.5"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212529"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvDeliveryAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#6c757d"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/rowCustomerPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#E8F5E9"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_phone_green"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvCustomerPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Special Instructions -->
            <LinearLayout
                android:id="@+id/noteContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_note_box"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Special Instructions"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#856404"
                    android:textAllCaps="true"
                    android:letterSpacing="0.5"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#856404"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>

            <!-- Action Buttons: Picking Up -->
            <LinearLayout
                android:id="@+id/layoutPickingUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnNavPickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigate to Pickup"
                    android:drawableStart="@drawable/ic_directions"
                    android:drawableTint="@color/white"
                    android:drawablePadding="8dp"
                    android:padding="14dp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnPickedUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mark as Picked Up"
                    android:drawableStart="@drawable/ic_check"
                    android:drawableTint="@color/white"
                    android:drawablePadding="8dp"
                    android:padding="14dp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/success"/>
            </LinearLayout>

            <!-- Action Buttons: In Progress -->
            <LinearLayout
                android:id="@+id/layoutInProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnNavDropoff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigate to Drop-off"
                    android:drawableStart="@drawable/ic_directions"
                    android:drawableTint="@color/white"
                    android:drawablePadding="8dp"
                    android:padding="14dp"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Complete Delivery"
                    android:drawableStart="@drawable/ic_check_circle"
                    android:drawableTint="@color/white"
                    android:drawablePadding="8dp"
                    android:padding="14dp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/success"/>
            </LinearLayout>

            <!-- Assigned: Waiting -->
            <LinearLayout
                android:id="@+id/layoutAssigned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/bg_waiting_box"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Waiting for pickup confirmation..."
                    android:textSize="14sp"
                    android:textColor="#004085"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

    <!-- Divider between items -->
    <View
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="#F5F7F6"/>
</LinearLayout>
