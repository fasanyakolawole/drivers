<?xml version="1.0" encoding="utf-8"?>
<!-- Login screen - visible gradient design, not plain white -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main gradient: light gray top to white bottom -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="#EBEBEB"
                android:centerColor="#F5F5F5"
                android:endColor="#FFFFFF"
                android:type="linear"/>
        </shape>
    </item>
    <!-- Diagonal accent: soft warm tint from top-left (matches dark orange theme) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="225"
                android:startColor="#35FFF0E0"
                android:centerColor="#15FFF8F0"
                android:endColor="#00FFFFFF"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
