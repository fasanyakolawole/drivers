<?xml version="1.0" encoding="utf-8"?>
<!-- Matches Drivers LoginScreen design exactly -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image - fits to screen -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/delivery"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Semi-transparent white overlay - makes background image whiter -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="25dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

        <!-- Logo Section - matches logoBackground: 100dp circle, dark orange -->
<!--        <FrameLayout-->
<!--            android:layout_width="100dp"-->
<!--            android:layout_height="100dp"-->
<!--            android:layout_marginBottom="40dp">-->

<!--            <ImageView-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="match_parent"-->
<!--                android:src="@drawable/main"-->
<!--                android:scaleType="centerCrop"-->
<!--                android:clipToOutline="true"-->
<!--                android:background="@drawable/rounded_bg"/>-->
<!--        </FrameLayout>-->

        <!-- Title and Subtitle - matches headerContainer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="45dp">

            <TextView
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/primary_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/naija_meals"
                android:textSize="34sp"
              />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_in_continue"
                android:textSize="16sp"
                android:textColor="@color/gray_text"/>
        </LinearLayout>

        <!-- Form Fields - matches formContainer, inputGroup style -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="30dp">

            <!-- Email Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="25dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/email"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_dark"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_login_input"
                    android:paddingHorizontal="15dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/login_primary"
                        android:layout_marginEnd="15dp"
                        android:contentDescription="@null"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:textColor="@color/gray_dark"
                        android:background="@null"
                        android:hint="@string/enter_email"
                        android:textColorHint="@color/gray_placeholder"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Password Field - with visibility toggle like Drivers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/password"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_dark"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_login_input"
                    android:paddingHorizontal="15dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/login_primary"
                        android:layout_marginEnd="15dp"
                        android:contentDescription="@null"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textSize="16sp"
                        android:textColor="@color/gray_dark"
                        android:background="@null"
                        android:hint="@string/enter_password"
                        android:textColorHint="@color/gray_placeholder"/>

                    <ImageButton
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="@color/gray_text"
                        android:contentDescription="@string/toggle_password"
                        android:scaleType="centerInside"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sign In Button - matches signInButton: dark orange, 55dp, 12dp radius -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="30dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignIn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/sign_in"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:elevation="8dp"
                app:backgroundTint="@color/primary_dark"/>

            <ProgressBar
                android:id="@+id/progressLogin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/white"/>
        </FrameLayout>

        <!-- Register link - matches registerContainer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_account"
                android:textSize="16sp"
                android:textColor="@color/gray_text"/>

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register"
                android:textSize="16sp"
                android:textColor="@color/login_primary"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>
        </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
